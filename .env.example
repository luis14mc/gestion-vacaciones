# =============================================================
# Variables de Entorno - Desarrollo Local
# =============================================================
# Copiar como .env.local (NO se sube a Git):
#   cp .env.example .env.local
#
# Secretos, Neon y SMTP van solo en .env.local.
# Ver docs/ARCHIVOS_NO_VERSIONADOS.md
# =============================================================

# Base de datos PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vacaciones
DATABASE_SSL=false

# Autenticación (NextAuth / Auth.js)
# Generar AUTH_SECRET con: openssl rand -base64 32
AUTH_SECRET=cambiar-en-desarrollo
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000

# Admin inicial (solo para scripts db:create-admin / db:setup)
ADMIN_EMAIL=admin@cni.hn
ADMIN_PASSWORD=cambiar-password-admin

# Cron (opcional en desarrollo)
CRON_SECRET=cambiar-cron-secret

# Email SMTP (opcional; también configurable en /configuracion)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM='"Sistema de Vacaciones CNI" <notificaciones@cni.hn>'

# URL pública para metadatos SEO
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Usuarios demo opcionales en seed (NO usar en producción)
# SEED_DEMO_USERS=true
# DEMO_USERS_PASSWORD=Demo1234!
