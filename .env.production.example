# =============================================================
# Variables de Entorno - Producción EC2
# =============================================================
# INSTRUCCIONES:
# 1. Copiar este archivo como .env.production
# 2. Completar TODOS los valores marcados con ← CAMBIAR
# 3. NUNCA subir este archivo al repositorio
# =============================================================

# ─────────────────────────────────────────────────────────
# BASE DE DATOS (PostgreSQL local en Docker)
# ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://cni_admin:CAMBIAR_PASSWORD@cni-postgres:5432/vacaciones

# Credenciales del contenedor PostgreSQL
POSTGRES_USER=cni_admin
POSTGRES_PASSWORD=CAMBIAR_PASSWORD
POSTGRES_DB=vacaciones

# Desactivar SSL para conexión local entre contenedores de Docker
DATABASE_SSL=false

# ─────────────────────────────────────────────────────────
# ADMIN INICIAL
# ─────────────────────────────────────────────────────────
ADMIN_EMAIL=soporteit@cni.hn
ADMIN_PASSWORD=CAMBIAR_PASSWORD_ADMIN

# ─────────────────────────────────────────────────────────
# AUTENTICACIÓN (NextAuth / Auth.js)
# ─────────────────────────────────────────────────────────
# Generar con: openssl rand -base64 32
AUTH_SECRET=CAMBIAR_AUTH_SECRET
NEXTAUTH_URL=https://vacaciones.cni.hn
AUTH_URL=https://vacaciones.cni.hn

# ─────────────────────────────────────────────────────────
# CRON (Transiciones automáticas)
# ─────────────────────────────────────────────────────────
# Generar con: openssl rand -hex 32
CRON_SECRET=CAMBIAR_CRON_SECRET

# ─────────────────────────────────────────────────────────
# EMAIL (Notificaciones via SMTP)
# ─────────────────────────────────────────────────────────
SMTP_HOST=smtp.tu-proveedor.com
SMTP_PORT=587
SMTP_USER=notificaciones@cni.hn
SMTP_PASSWORD=CAMBIAR_PASSWORD_SMTP
SMTP_FROM='"Sistema de Vacaciones CNI" <notificaciones@cni.hn>'

# ─────────────────────────────────────────────────────────
# NODE.JS (Optimización de memoria)
# ─────────────────────────────────────────────────────────
NODE_ENV=production
NODE_OPTIONS=--max-old-space-size=768
