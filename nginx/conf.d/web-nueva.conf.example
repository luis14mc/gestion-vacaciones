# =============================================================
# Placeholder: Virtual Host para la Web Nueva (EJEMPLO)
# =============================================================
# Reemplazar con la configuración real de tu otra app
# =============================================================

# Upstream para la web nueva (Next.js frontend)
upstream web_nueva_frontend {
    server cni-web-nueva:3001;    # ← Ajustar nombre y puerto
    keepalive 8;
}

# Upstream para la web nueva (Django backend)
upstream web_nueva_backend {
    server cni-web-django:8000;   # ← Ajustar nombre y puerto
    keepalive 8;
}

server {
    listen 80;
    server_name www.cni.hn cni.hn;  # ← CAMBIAR POR TU DOMINIO

    # API del backend Django
    location /api/ {
        limit_req zone=api_limit burst=20 nodelay;

        proxy_pass http://web_nueva_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";
    }

    # Django Admin
    location /admin/ {
        proxy_pass http://web_nueva_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Archivos estáticos de Django
    location /static/ {
        proxy_pass http://web_nueva_backend;
        proxy_cache static_cache;
        proxy_cache_valid 200 30d;
        add_header Cache-Control "public, max-age=2592000";
    }

    # Assets estáticos de Next.js
    location /_next/static/ {
        proxy_pass http://web_nueva_frontend;
        proxy_cache static_cache;
        proxy_cache_valid 200 365d;
        add_header Cache-Control "public, max-age=31536000, immutable";
    }

    # Todo lo demás va al frontend Next.js
    location / {
        proxy_pass http://web_nueva_frontend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
