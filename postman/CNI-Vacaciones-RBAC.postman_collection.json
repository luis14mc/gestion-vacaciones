{
  "info": {
    "name": "CNI Vacaciones - RBAC Tests",
    "description": "Colección completa para testing de endpoints con RBAC - Sistema de Gestión de Vacaciones CNI Honduras",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{authToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "01. Autenticación",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.environment.set('authToken', jsonData.authToken);",
                  "    console.log('Token guardado:', jsonData.authToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/callback/credentials",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "callback", "credentials"]
            }
          }
        }
      ]
    },
    {
      "name": "02. Solicitudes",
      "item": [
        {
          "name": "GET Solicitudes - Ver todas/propias según rol",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/solicitudes?page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "solicitudes"],
              "query": [
                {"key": "page", "value": "1"},
                {"key": "pageSize", "value": "20"}
              ]
            }
          }
        },
        {
          "name": "POST Solicitud - Crear nueva",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usuarioId\": 4,\n  \"tipoAusenciaId\": 1,\n  \"fechaInicio\": \"2026-02-01\",\n  \"fechaFin\": \"2026-02-05\",\n  \"cantidad\": 5,\n  \"unidad\": \"dias\",\n  \"motivo\": \"Vacaciones familiares\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/solicitudes",
              "host": ["{{baseUrl}}"],
              "path": ["api", "solicitudes"]
            }
          }
        },
        {
          "name": "PATCH Aprobar - Jefe (solo su depto)",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accion\": \"aprobar_jefe\",\n  \"comentarios\": \"Aprobado por jefe\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/solicitudes/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "solicitudes", "1"]
            }
          }
        },
        {
          "name": "PATCH Aprobar - RRHH (todas)",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accion\": \"aprobar_rrhh\",\n  \"comentarios\": \"Aprobado por RRHH\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/solicitudes/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "solicitudes", "1"]
            }
          }
        },
        {
          "name": "PATCH Rechazar",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accion\": \"rechazar\",\n  \"comentarios\": \"No se puede aprobar en estas fechas\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/solicitudes/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "solicitudes", "1"]
            }
          }
        }
      ]
    },
